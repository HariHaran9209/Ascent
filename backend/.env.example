# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Server ---
PORT=5000
CLIENT_URL=http://localhost:5173

# --- Database ---
# MongoDB Atlas connection string (Atlas free tier works fine):
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/iitm-progress?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/iitm-progress

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# --- OTP ---
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# --- Email (Nodemailer / Gmail) ---
# To send emails using Gmail, you must generate a 16-character App Password.
# Standard Google passwords do not work due to security policy.
# Setup:
#   1. Go to your Google Account -> Security.
#   2. Enable 2-Step Verification if not already enabled.
#   3. Search for "App Passwords" and create one.
#   4. Use that 16-character password as EMAIL_PASS below.
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your_gmail_address@gmail.com
