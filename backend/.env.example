# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Server ---
PORT=5000
CLIENT_URL=http://localhost:5173

# --- Database ---
# MongoDB Atlas connection string (Atlas free tier works fine):
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/iitm-progress?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/iitm-progress

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# --- OTP ---
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# --- Email (SendGrid) ---
# Why SendGrid instead of raw SMTP: many free hosting tiers (Render's
# free web services, as of Sept 2025) block outbound traffic on SMTP
# ports 25/465/587 entirely. SendGrid's API runs over normal HTTPS, so
# it isn't affected. Free tier = 100 emails/day, plenty for a class.
#
# Setup (no domain required):
#   1. Sign up at sendgrid.com, verify your account.
#   2. Settings -> Sender Authentication -> Single Sender Verification.
#      Verify an email address you control (your own Gmail is fine) —
#      you'll get a confirmation link, click it.
#   3. Settings -> API Keys -> create one with "Mail Send" permission.
#   4. SENDGRID_API_KEY = that key. EMAIL_FROM = the exact address you
#      just verified in step 2 (must match exactly, or sends will fail).
SENDGRID_API_KEY=SG.your_api_key_here
EMAIL_FROM=your_verified_sender@gmail.com
